PORT=3001
NODE_ENV=production

# MongoDB Atlas - kitchen_db (kitchens + meals collections)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/kitchen_db?retryWrites=true&w=majority

# Existing homemaker website DB (read-only)
HOMEMAKER_MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<homemaker_db_name>?retryWrites=true&w=majority
HOMEMAKER_COLLECTION_NAME=homemakers

GOOGLE_MAPS_API_KEY=your_google_maps_api_key

AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name

DISTANCE_CACHE_TTL_MIN=15
